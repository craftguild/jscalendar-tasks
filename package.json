{
  "name": "jscalendar-tasks",
  "version": "0.1.8",
  "private": true,
  "packageManager": "npm@11.6.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "db:reset-demo": "prisma migrate deploy && prisma db seed",
    "release": "commit-and-tag-version",
    "release:dry-run": "commit-and-tag-version --dry-run",
    "release:prepare": "commit-and-tag-version --skip.commit --skip.tag"
  },
  "dependencies": {
    "@craftguild/jscalendar": "^0.7.2",
    "@prisma/adapter-better-sqlite3": "^6.19.3",
    "@prisma/client": "^6.19.3",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.2.3",
    "next": "16.2.4",
    "prisma": "^6.19.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "^5.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "commit-and-tag-version": "^12.7.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  },
  "commit-and-tag-version": {
    "releaseCommitMessageFormat": "chore: prepare {{currentTag}} release"
  }
}
